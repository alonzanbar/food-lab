---
import Layout from '../components/Layout.astro';
import SectionImage from '../components/SectionImage.astro';
import { images } from '../config/images';
const t = (await import('../content/he.json')).default;
---

<Layout title={`${t.about.title} | Food Lab`} description={t.about.content} locale="he">
  <section class="py-20 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl font-bold text-slate-900 mb-6">{t.about.title}</h1>
          <p class="text-slate-600 leading-relaxed">{t.about.content}</p>
          <a href="/#cta" class="inline-block mt-8 px-6 py-3 bg-teal-600 text-white font-medium rounded-lg hover:bg-teal-700 transition">
            {t.hero.ctaPrimary}
          </a>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-xl">
          <SectionImage src={images.about} alt="אודות Food Lab" aspect="video" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 sm:px-6 bg-slate-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-900 mb-12 text-center">{t.about.teamTitle}</h2>
      <div class="grid md:grid-cols-2 gap-12">
        {t.about.team.map((member) => (
          <div class="flex flex-col sm:flex-row gap-6 p-6 bg-white rounded-2xl shadow-sm border border-slate-100">
            <div class="shrink-0">
              <img src={member.image} alt={member.name} class="w-40 h-40 object-cover rounded-xl" loading="lazy" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-slate-900">{member.name}</h3>
              <p class="text-teal-600 font-medium text-sm mt-1">{member.role}</p>
              <p class="text-slate-600 mt-3 text-sm leading-relaxed">{member.bio}</p>
              <p class="text-slate-500 mt-2 text-sm leading-relaxed">{member.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
