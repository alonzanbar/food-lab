---
import Layout from '../../components/Layout.astro';
import DemoForm from '../../components/DemoForm.astro';
import SectionImage from '../../components/SectionImage.astro';
import { images } from '../../config/images';
const t = (await import('../../content/en.json')).default;
---

<Layout title={`${t.contact.title} | Food Lab`} description={t.contact.intro} locale="en">
  <section class="py-20 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl font-bold text-slate-900 mb-4">{t.contact.title}</h1>
          <p class="text-slate-600 mb-8">{t.contact.intro}</p>
          <h2 class="text-xl font-semibold text-slate-800 mb-4">{t.contact.formTitle}</h2>
          <DemoForm locale="en" />
        </div>
        <div class="rounded-2xl overflow-hidden shadow-xl">
          <SectionImage src={images.contact} alt="Contact" aspect="video" />
        </div>
      </div>
    </div>
  </section>
</Layout>
