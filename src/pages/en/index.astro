---
import Layout from '../../components/Layout.astro';
import DemoForm from '../../components/DemoForm.astro';
const t = (await import('../../content/en.json')).default;
---

<Layout title={`${t.hero.headline} | Food Lab`} description={t.hero.subheadline} locale="en">
  <!-- Hero -->
  <section class="py-20 px-4 sm:px-6 bg-slate-100">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-4">{t.hero.headline}</h1>
      <p class="text-xl text-slate-600 mb-8">{t.hero.subheadline}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#cta" class="inline-flex items-center justify-center px-6 py-3 bg-teal-600 text-white font-medium rounded-lg hover:bg-teal-700 transition">
          {t.hero.ctaPrimary}
        </a>
        <a href="#how" class="inline-flex items-center justify-center px-6 py-3 border border-slate-300 text-slate-700 font-medium rounded-lg hover:bg-slate-50 transition">
          {t.hero.ctaSecondary}
        </a>
      </div>
      <div class="mt-12 rounded-lg overflow-hidden bg-slate-200 aspect-video max-w-2xl mx-auto flex items-center justify-center text-slate-500">
        Hero image placeholder
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section id="problem" class="py-16 px-4 sm:px-6 scroll-mt-20">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-900 mb-6">{t.problem.title}</h2>
      <p class="text-slate-600 mb-6">{t.problem.intro}</p>
      <ul class="list-disc list-inside text-slate-600 mb-6 space-y-2">
        {t.problem.items.map((item) => <li>{item}</li>)}
      </ul>
      <p class="font-medium text-slate-700 mb-2">Pain points:</p>
      <ul class="list-disc list-inside text-slate-600 space-y-1">
        {t.problem.painPoints.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <!-- Solution -->
  <section id="solution" class="py-16 px-4 sm:px-6 bg-slate-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-900 mb-6">{t.solution.title}</h2>
      <p class="text-slate-600 mb-6">{t.solution.intro}</p>
      <ul class="list-disc list-inside text-slate-600 space-y-2">
        {t.solution.items.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <!-- How it works -->
  <section id="how" class="py-16 px-4 sm:px-6 scroll-mt-20">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-900 mb-12 text-center">{t.howItWorks.title}</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {t.howItWorks.steps.map((step) => (
          <div class="p-4 border border-slate-200 rounded-lg bg-white">
            <span class="text-2xl font-bold text-teal-600">{step.num}</span>
            <h3 class="font-semibold text-slate-900 mt-2">{step.title}</h3>
            <p class="text-sm text-slate-600 mt-1">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section id="usecases" class="py-16 px-4 sm:px-6 bg-slate-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-900 mb-12 text-center">{t.useCases.title}</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {t.useCases.items.map((item) => (
          <div class="p-4 bg-white border border-slate-200 rounded-lg">
            <h3 class="font-semibold text-slate-900">{item.title}</h3>
            <p class="text-sm text-slate-600 mt-1">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Compliance -->
  <section id="compliance" class="py-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-900 mb-6">{t.compliance.title}</h2>
      <p class="text-slate-600 mb-4">{t.compliance.intro}</p>
      <div class="flex flex-wrap gap-2 mb-6">
        {t.compliance.items.map((item) => (
          <span class="px-3 py-1 bg-slate-200 rounded-full text-sm font-medium">{item}</span>
        ))}
      </div>
      <p class="text-sm text-slate-500 italic">{t.compliance.disclaimer}</p>
    </div>
  </section>

  <!-- Benefits -->
  <section id="benefits" class="py-16 px-4 sm:px-6 bg-slate-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-900 mb-8">{t.benefits.title}</h2>
      <ul class="grid sm:grid-cols-2 gap-3">
        {t.benefits.items.map((item) => (
          <li class="flex items-start gap-2">
            <span class="text-teal-600 mt-0.5">✓</span>
            <span class="text-slate-700">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-16 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-slate-900 mb-8">{t.faq.title}</h2>
      <dl class="space-y-6">
        {t.faq.items.map((item) => (
          <div>
            <dt class="font-semibold text-slate-900">{item.q}</dt>
            <dd class="mt-1 text-slate-600">{item.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Final CTA -->
  <section id="cta" class="py-16 px-4 sm:px-6 bg-slate-800 text-white scroll-mt-20">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-2">{t.cta.title}</h2>
      <p class="text-slate-300 mb-8">{t.cta.subtitle}</p>
      <div class="bg-white rounded-lg p-6 text-left text-slate-800">
        <DemoForm locale="en" />
      </div>
    </div>
  </section>
</Layout>
