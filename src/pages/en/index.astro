---
import Layout from '../../components/Layout.astro';
import DemoForm from '../../components/DemoForm.astro';
import SectionImage from '../../components/SectionImage.astro';
import IconBadge from '../../components/IconBadge.astro';
import UseCaseCard from '../../components/UseCaseCard.astro';
import DeviceMockup from '../../components/DeviceMockup.astro';
import DashboardMockup from '../../components/DashboardMockup.astro';
import { images } from '../../config/images';
const t = (await import('../../content/en.json')).default;
const useCaseIcons = ['inbox', 'settings', 'flask', 'chart', 'alert', 'check', 'document', 'users'] as const;
---

<Layout title={`${t.hero.headline} | Food Lab`} description={t.hero.subheadline} locale="en">
  <!-- Hero -->
  <section class="py-20 px-4 sm:px-6 bg-gradient-to-b from-teal-50 to-slate-100">
    <div class="max-w-6xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-teal-100 text-teal-700 text-sm font-medium mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Digital Quality Management
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-4">{t.hero.headline}</h1>
      <p class="text-xl text-slate-600 mb-8">{t.hero.subheadline}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#cta" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-teal-600 text-white font-medium rounded-lg hover:bg-teal-700 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          {t.hero.ctaPrimary}
        </a>
        <a href="#how" class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-slate-300 text-slate-700 font-medium rounded-lg hover:bg-slate-50 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
          {t.hero.ctaSecondary}
        </a>
      </div>
      <div class="mt-16 flex flex-wrap justify-center items-end gap-6 lg:gap-12">
        <DeviceMockup type="tablet" class="scale-90 lg:scale-100">
          <DashboardMockup variant="dashboard" />
        </DeviceMockup>
        <DeviceMockup type="phone" class="scale-75 lg:scale-90 -mb-4">
          <DashboardMockup variant="form" />
        </DeviceMockup>
      </div>
    </div>
  </section>

  <!-- Problem - Visual -->
  <section id="problem" class="relative py-20 px-4 sm:px-6 scroll-mt-20 bg-white overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%230d9488\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');" />
    <div class="relative max-w-6xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
        <div class="group flex flex-col items-center p-6 rounded-2xl bg-white border border-slate-200/80 shadow-sm hover:shadow-md hover:border-teal-200/50 transition-all duration-300">
          <div class="w-14 h-14 rounded-xl bg-amber-100 text-amber-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9M3 15h6"/></svg>
          </div>
          <span class="text-sm font-medium text-slate-700 text-center">{t.problem.painPoints[0]}</span>
        </div>
        <div class="group flex flex-col items-center p-6 rounded-2xl bg-white border border-slate-200/80 shadow-sm hover:shadow-md hover:border-teal-200/50 transition-all duration-300">
          <div class="w-14 h-14 rounded-xl bg-stone-100 text-stone-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
          </div>
          <span class="text-sm font-medium text-slate-700 text-center">{t.problem.painPoints[1]}</span>
        </div>
        <div class="group flex flex-col items-center p-6 rounded-2xl bg-white border border-slate-200/80 shadow-sm hover:shadow-md hover:border-teal-200/50 transition-all duration-300">
          <div class="w-14 h-14 rounded-xl bg-rose-100 text-rose-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <span class="text-sm font-medium text-slate-700 text-center">{t.problem.painPoints[2]}</span>
        </div>
        <div class="group flex flex-col items-center p-6 rounded-2xl bg-white border border-slate-200/80 shadow-sm hover:shadow-md hover:border-teal-200/50 transition-all duration-300">
          <div class="w-14 h-14 rounded-xl bg-orange-100 text-orange-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          </div>
          <span class="text-sm font-medium text-slate-700 text-center">{t.problem.painPoints[3]}</span>
        </div>
        <div class="group flex flex-col items-center p-6 rounded-2xl bg-white border border-slate-200/80 shadow-sm hover:shadow-md hover:border-teal-200/50 transition-all duration-300 col-span-2 lg:col-span-1">
          <div class="w-14 h-14 rounded-xl bg-slate-200 text-slate-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h.01M12 10h.01M16 10h.01"/></svg>
          </div>
          <span class="text-sm font-medium text-slate-700 text-center">{t.problem.painPoints[4]}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution -->
  <section id="solution" class="py-20 px-4 sm:px-6 bg-teal-50/50">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex items-center gap-2 mb-4">
            <div class="w-10 h-10 rounded-xl bg-teal-100 text-teal-600 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h2 class="text-3xl font-bold text-slate-900">{t.solution.title}</h2>
          </div>
          <p class="text-slate-600 mb-6">{t.solution.intro}</p>
          <ul class="space-y-4">
            {t.solution.items.map((item) => (
              <li class="flex items-start gap-3 text-slate-600 p-3 rounded-lg bg-white/80">
                <div class="w-8 h-8 rounded-lg bg-teal-100 text-teal-600 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="flex justify-center gap-4">
          <DeviceMockup type="tablet" class="shadow-2xl">
            <DashboardMockup variant="dashboard" />
          </DeviceMockup>
          <DeviceMockup type="phone" class="hidden lg:block -mt-8 shadow-2xl">
            <DashboardMockup variant="list" />
          </DeviceMockup>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how" class="py-20 px-4 sm:px-6 scroll-mt-20 bg-slate-50">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-center gap-2 mb-12">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-teal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        <h2 class="text-3xl font-bold text-slate-900">{t.howItWorks.title}</h2>
      </div>
      <div class="relative">
        <div class="hidden lg:block absolute top-12 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-teal-200 to-transparent" />
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 relative">
          {t.howItWorks.steps.map((step) => (
            <div class="group p-6 border border-slate-200 rounded-2xl bg-white shadow-sm hover:shadow-lg hover:border-teal-200 transition-all">
              <div class="w-12 h-12 rounded-xl bg-teal-100 text-teal-700 flex items-center justify-center font-bold text-lg mb-4 group-hover:scale-110 transition-transform">
                {step.num}
              </div>
              <h3 class="font-semibold text-slate-900">{step.title}</h3>
              <p class="text-sm text-slate-600 mt-2">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="mt-16 flex justify-center">
        <DeviceMockup type="tablet" class="max-w-md">
          <DashboardMockup variant="dashboard" />
        </DeviceMockup>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section id="usecases" class="py-20 px-4 sm:px-6 bg-amber-50/30">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-center gap-2 mb-12">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        <h2 class="text-3xl font-bold text-slate-900">{t.useCases.title}</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {t.useCases.items.map((item, i) => (
          <UseCaseCard title={item.title} desc={item.desc} icon={useCaseIcons[i]} />
        ))}
      </div>
    </div>
  </section>

  <!-- Compliance -->
  <section id="compliance" class="py-20 px-4 sm:px-6 bg-blue-50/40">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center gap-2 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <h2 class="text-3xl font-bold text-slate-900">{t.compliance.title}</h2>
      </div>
      <p class="text-slate-600 mb-8">{t.compliance.intro}</p>
      <div class="flex flex-wrap gap-4 mb-8">
        {t.compliance.items.map((item) => (
          <IconBadge label={item} icon="cert" />
        ))}
      </div>
      <p class="text-sm text-slate-500 italic">{t.compliance.disclaimer}</p>
    </div>
  </section>

  <!-- Benefits -->
  <section id="benefits" class="py-20 px-4 sm:px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex items-center gap-2 mb-10">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-teal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            <h2 class="text-3xl font-bold text-slate-900">{t.benefits.title}</h2>
          </div>
          <ul class="grid sm:grid-cols-2 gap-4">
            {t.benefits.items.map((item, i) => (
              <li class="flex items-start gap-3 p-4 rounded-xl bg-slate-50 border border-slate-100">
                <div class="w-10 h-10 rounded-lg bg-teal-100 text-teal-600 flex items-center justify-center shrink-0">
                  {i === 0 && <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm6 0a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/></svg>}
                  {i === 1 && <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>}
                  {i === 2 && <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>}
                  {i === 3 && <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>}
                  {i === 4 && <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>}
                  {i === 5 && <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>}
                </div>
                <span class="text-slate-700 pt-1">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="flex justify-center">
          <DeviceMockup type="tablet" class="shadow-2xl">
            <DashboardMockup variant="dashboard" />
          </DeviceMockup>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-20 px-4 sm:px-6 bg-slate-50">
    <div class="max-w-3xl mx-auto">
      <div class="flex items-center gap-2 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-slate-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <h2 class="text-3xl font-bold text-slate-900">{t.faq.title}</h2>
      </div>
      <dl class="space-y-6">
        {t.faq.items.map((item) => (
          <div class="p-4 rounded-xl bg-white border border-slate-100 shadow-sm">
            <dt class="font-semibold text-slate-900 flex items-start gap-2">
              <span class="text-teal-500 shrink-0">Q</span>
              {item.q}
            </dt>
            <dd class="mt-2 text-slate-600 flex items-start gap-2 ms-6">
              <span class="text-teal-500 shrink-0 font-medium">A</span>
              {item.a}
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Final CTA -->
  <section id="cta" class="relative py-20 px-4 sm:px-6 text-white scroll-mt-20 overflow-hidden">
    <div class="absolute inset-0">
      <img src={images.ctaBackground} alt="" class="w-full h-full object-cover" loading="lazy" />
      <div class="absolute inset-0 bg-slate-900/80" />
    </div>
    <div class="relative max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-2">{t.cta.title}</h2>
      <p class="text-slate-300 mb-8">{t.cta.subtitle}</p>
      <div class="bg-white rounded-2xl p-8 text-start text-slate-800 shadow-xl">
        <DemoForm locale="en" />
      </div>
    </div>
  </section>
</Layout>
