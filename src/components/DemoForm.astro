---
interface Props {
  locale?: string;
}

const { locale = 'he' } = Astro.props;
const t = locale === 'he' ? (await import('../content/he.json')).default : (await import('../content/en.json')).default;
const formT = t.form;
const ctaT = t.cta;

// Formspree: replace with your endpoint from https://formspree.io
const formAction = 'https://formspree.io/f/xxxxx';
---

<form action={formAction} method="POST" class="space-y-4 max-w-md">
  <input type="hidden" name="_subject" value="Demo request - Food Lab" />
  <input type="hidden" name="_language" value={locale} />
  <div>
    <label for="name" class="block text-sm font-medium text-slate-700 mb-1">{formT.name}</label>
    <input type="text" id="name" name="name" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500" />
  </div>
  <div>
    <label for="company" class="block text-sm font-medium text-slate-700 mb-1">{formT.company}</label>
    <input type="text" id="company" name="company" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500" />
  </div>
  <div>
    <label for="role" class="block text-sm font-medium text-slate-700 mb-1">{formT.role}</label>
    <input type="text" id="role" name="role" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500" />
  </div>
  <div>
    <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">{formT.phone}</label>
    <input type="tel" id="phone" name="phone" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500" />
  </div>
  <div>
    <label for="email" class="block text-sm font-medium text-slate-700 mb-1">{formT.email}</label>
    <input type="email" id="email" name="email" required class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500" />
  </div>
  <div>
    <label for="message" class="block text-sm font-medium text-slate-700 mb-1">{formT.message}</label>
    <textarea id="message" name="message" rows="4" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"></textarea>
  </div>
  <button type="submit" class="w-full px-4 py-3 bg-teal-600 text-white font-medium rounded-lg hover:bg-teal-700 transition">
    {ctaT.submit}
  </button>
</form>
