---
import Base from '../layouts/Base.astro';

interface Props {
  title: string;
  description?: string;
  locale?: string;
}

const { title, description, locale = 'he' } = Astro.props;
const t = locale === 'he' ? (await import('../content/he.json')).default : (await import('../content/en.json')).default;

const pathname = Astro.url.pathname;
// Hebrew default: /, /about. English: /en, /en/about. Switch: he<->en
const otherUrl = locale === 'he'
  ? (pathname === '/' ? '/en' : `/en${pathname}`)
  : (pathname === '/en' ? '/' : pathname.replace(/^\/en/, '') || '/');
---

<Base title={title} description={description} locale={locale}>
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-slate-200">
    <nav class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
      <a href={locale === 'he' ? '/' : `/${locale}`} class="text-lg font-semibold text-slate-800 hover:text-slate-600 transition">
        Food Lab
      </a>
      <div class="flex items-center gap-6">
        <a href={locale === 'he' ? '/about' : `/${locale}/about`} class="text-slate-600 hover:text-slate-800 transition">{t.nav.about}</a>
        <a href={locale === 'he' ? '/contact' : `/${locale}/contact`} class="text-slate-600 hover:text-slate-800 transition">{t.nav.contact}</a>
        <a href={otherUrl} class="text-sm text-slate-500 hover:text-slate-700 transition" aria-label="Switch language">
          {t.nav.langSwitch}
        </a>
        <a href={locale === 'he' ? '/#cta' : `/${locale}/#cta`} class="inline-flex items-center px-4 py-2 bg-teal-600 text-white rounded-lg font-medium hover:bg-teal-700 transition">
          {t.hero.ctaPrimary}
        </a>
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="bg-slate-800 text-slate-300 py-12 mt-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row justify-between gap-6">
      <div>
        <span class="font-semibold text-white">Food Lab</span>
        <p class="mt-2 text-sm">{t.footer.copyright}</p>
      </div>
      <div class="flex gap-8">
        <div>
          <h3 class="font-medium text-white mb-2">{t.footer.links}</h3>
          <a href={locale === 'he' ? '/about' : `/${locale}/about`} class="block text-sm hover:text-white transition">{t.nav.about}</a>
          <a href={locale === 'he' ? '/contact' : `/${locale}/contact`} class="block text-sm hover:text-white transition">{t.nav.contact}</a>
        </div>
        <div>
          <h3 class="font-medium text-white mb-2">{t.footer.legal}</h3>
          <a href={locale === 'he' ? '/privacy' : `/${locale}/privacy`} class="block text-sm hover:text-white transition">{t.nav.privacy}</a>
        </div>
      </div>
    </div>
  </footer>
</Base>
