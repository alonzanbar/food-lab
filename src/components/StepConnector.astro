---
interface Props {
  steps: number;
  class?: string;
}

const { steps = 4, class: className = '' } = Astro.props;
---

<div class={`flex items-center justify-between gap-2 ${className}`} aria-hidden="true">
  {Array.from({ length: steps }).map((_, i) => (
    <>
      <div class="flex flex-col items-center flex-1">
        <div class="w-10 h-10 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center font-bold text-sm">{i + 1}</div>
      </div>
      {i < steps - 1 && (
        <div class="flex-1 h-0.5 bg-teal-200 min-w-[20px] hidden sm:block" />
      )}
    </>
  ))}
</div>
