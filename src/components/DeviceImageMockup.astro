---
interface Props {
  type?: 'tablet' | 'phone';
  src: string;
  alt?: string;
  class?: string;
}

const { type = 'tablet', src, alt = '', class: className = '' } = Astro.props;
---

<div class={`relative inline-block ${className}`}>
  {type === 'tablet' && (
    <div class="relative bg-slate-800 rounded-[2rem] p-3 shadow-2xl">
      <div class="rounded-xl overflow-hidden aspect-[4/3] min-w-[280px] max-w-[400px] bg-slate-200">
        <img src={src} alt={alt} class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="absolute top-4 left-1/2 -translate-x-1/2 w-16 h-1.5 bg-slate-600 rounded-full" />
    </div>
  )}
  {type === 'phone' && (
    <div class="relative bg-slate-800 rounded-[2.5rem] p-2 shadow-2xl">
      <div class="absolute top-4 left-1/2 -translate-x-1/2 w-12 h-5 bg-slate-700 rounded-full" />
      <div class="rounded-[1.5rem] overflow-hidden aspect-[9/19] min-w-[140px] max-w-[180px] mt-6 bg-slate-200">
        <img src={src} alt={alt} class="w-full h-full object-cover" loading="lazy" />
      </div>
    </div>
  )}
</div>
